{
	"$schema": "https://json.schemastore.org/claude-code-settings.json",
	"extraKnownMarketplaces": {
		"status-pipe": {
			"source": {
				"source": "github",
				"repo": "irl-llc/status-pipe"
			}
		}
	},
	"enabledPlugins": {
		"status-pipe@status-pipe": true
	},
	"permissions": {
		"allow": [
			"Bash(${CLAUDE_PLUGIN_ROOT}/bin/post-comment:*)",
			"Bash(${CLAUDE_PLUGIN_ROOT}/bin/fetch-comments:*)"
		],
		"deny": [
			"Bash(gh issue comment:*)",
			"Bash(gh pr comment:*)"
		]
	}
}
