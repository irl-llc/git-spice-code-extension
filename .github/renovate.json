{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommitTypeAll(chore)"
  ],
  "schedule": ["before 6am on monday"],
  "labels": ["dependencies"],
  "packageRules": [
    {
      "matchManagers": ["custom.regex"],
      "matchPackageNames": ["microsoft/vscode"],
      "groupName": "vscode-version",
      "commitMessageTopic": "VS Code pin",
      "prBodyNotes": [
        ":warning: This bump may invalidate the Playwright snapshot images in `src/test/e2e/playwright/*.spec.ts-snapshots/`. After merging, run `npm run test:e2e:playwright:docker:update` and commit the regenerated PNGs in a follow-up."
      ]
    },
    {
      "matchManagers": ["custom.regex"],
      "matchDepNames": ["abhinav/git-spice#ed-irl/integration"],
      "groupName": "gs-integration-version",
      "commitMessageTopic": "gs integration-branch pin",
      "prBodyNotes": [
        ":test_tube: This advances the **beta** `gs` build to the latest commit on `abhinav/git-spice`'s `ed-irl/integration` branch. After merging, run `npm run gs:fetch` locally to rebuild `.gs/bin/gs`."
      ]
    },
    {
      "matchManagers": ["custom.regex"],
      "matchDepNames": ["abhinav/git-spice"],
      "groupName": "gs-stock-version",
      "commitMessageTopic": "gs stock release pin",
      "prBodyNotes": [
        ":package: This advances the **stock** `gs` build to the latest tagged release of `abhinav/git-spice`. After merging, run `npm run gs:fetch` locally to rebuild the stock binary."
      ]
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Bump VS Code version pinned for E2E tests",
      "fileMatch": ["^\\.vscode-version$"],
      "matchStrings": ["^(?<currentValue>[0-9.]+)\\s*$"],
      "depNameTemplate": "microsoft/vscode",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^(?<version>\\d+\\.\\d+\\.\\d+)$"
    },
    {
      "customType": "regex",
      "description": "Bump pinned gs beta binary to abhinav/git-spice's ed-irl/integration branch HEAD",
      "fileMatch": ["^\\.gs-version$"],
      "matchStrings": ["^(?<currentDigest>[0-9a-f]{40})\\s*$"],
      "depNameTemplate": "abhinav/git-spice#ed-irl/integration",
      "packageNameTemplate": "https://github.com/abhinav/git-spice",
      "datasourceTemplate": "git-refs",
      "currentValueTemplate": "ed-irl/integration"
    },
    {
      "customType": "regex",
      "description": "Bump pinned gs stock binary to abhinav/git-spice's latest release tag",
      "fileMatch": ["^\\.gs-stock-version$"],
      "matchStrings": ["^(?<currentValue>v?[0-9][0-9A-Za-z.\\-+]*)\\s*$"],
      "depNameTemplate": "abhinav/git-spice",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v?(?<version>\\d+\\.\\d+\\.\\d+)$"
    }
  ]
}
